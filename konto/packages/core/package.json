{
  "name": "@konto-ledger/core",
  "version": "0.1.1",
  "description": "Strictly-typed double-entry ledger primitives for PostgreSQL.",
  "license": "MIT",
  "homepage": "https://github.com/aetosdios27/Konto#readme",
  "bugs": {
    "url": "https://github.com/aetosdios27/Konto/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aetosdios27/Konto"
  },
  "keywords": [
    "ledger",
    "accounting",
    "double-entry",
    "postgres",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema.sql"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --clean",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@konto-ledger/types": "workspace:^",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22",
    "@types/uuid": "^11.0.0",
    "testcontainers": "^11.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "uuid": "^11.1.0",
    "vitest": "^2.1.9"
  }
}
