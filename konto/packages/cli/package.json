{
  "name": "@konto-ledger/cli",
  "version": "0.1.1",
  "description": "CLI and typed client generator for Konto ledgers.",
  "license": "MIT",
  "homepage": "https://github.com/aetosdios27/Konto#readme",
  "bugs": {
    "url": "https://github.com/aetosdios27/Konto/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aetosdios27/Konto.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "ledger",
    "cli",
    "codegen",
    "postgres",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "bin": {
    "konto": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@konto-ledger/types": "workspace:^",
    "cac": "^6.7.14",
    "dotenv": "^16.4.5",
    "jiti": "^2.6.1",
    "picocolors": "^1.0.1",
    "postgres": "^3.4.5"
  },
  "peerDependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@konto-ledger/core": "workspace:^",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22",
    "testcontainers": "^11.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9",
    "zod": "^3.25.76"
  }
}
